# Appwrite Configuration
VITE_APPWRITE_ENDPOINT="https://cloud.appwrite.io/v1"
VITE_APPWRITE_PROJECT_ID="your-project-id"
VITE_APPWRITE_DB_NAME="devwatch_db"
VITE_APPWRITE_COLLECTION_SESSIONS="sessions"
VITE_APPWRITE_COLLECTION_ACTIVITY_LOGS="activityLogs"
VITE_APPWRITE_COLLECTION_REPORTS="reports"
VITE_APPWRITE_COLLECTION_SETTINGS="settings"
VITE_APPWRITE_COLLECTION_HACKATHONS="hackathons"
VITE_APPWRITE_FUNCTION_SETTINGS="sonar-settings"

# Optional during migration:
# This is required for the web admin's function fallback in local/dev while
# hackathon storage and some admin reads still rely on Appwrite functions.
VITE_DEV_KEY="developer:your-build-signing-key"

# SMTP Configuration for Contact Form
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false" # "true" for port 465, "false" otherwise
SMTP_USER="your-email@example.com"
SMTP_PASS="your-email-password-or-app-password"
SMTP_FROM="your-email@example.com"

# The inbox where contact form messages will be sent
# If omitted, messages will be sent to the SMTP_FROM address instead
CONTACT_INBOX_EMAIL="contact@yourdomain.com"
